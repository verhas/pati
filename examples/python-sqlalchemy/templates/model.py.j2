from sqlalchemy import Column, DateTime, Integer, String, func
from sqlalchemy.orm import declarative_base

Base = declarative_base()


class {{ class_name }}(Base):
    __tablename__ = '{{ table_name }}'

{% for field in fields %}
    {{ field.name }} = Column(
        {{ field.type }}{{ ",  # primary key" if field.primary_key | default(false) else "" }}{{ ",  # unique" if field.unique | default(false) else "" }}{{ ",  # nullable" if field.nullable is sameas false else "" }}
        {% if field.primary_key | default(false) %}primary_key=True{% endif %}{{ "," if (field.default | default(false) or (field.unique | default(false) or field.nullable is sameas false)) and field.primary_key | default(false) else "" }}
        {% if field.default | default(false) %}default={{ field.default }}{% endif %}{{ "," if field.unique | default(false) and field.default | default(false) else "" }}
        {% if field.unique | default(false) %}unique=True{% endif %}{{ "," if field.nullable is sameas false and (field.unique | default(false) or field.default | default(false)) else "" }}
        {% if field.nullable is sameas false %}nullable=False{% endif %}
    )

{% endfor %}
    def __repr__(self):
        return f"<{{ class_name }}(id={self.id}, username={self.username})>"
